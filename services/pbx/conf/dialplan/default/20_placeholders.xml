<include>
  <extension name="voxagent_outbound_placeholder">
    <condition field="destination_number" expression="^9(\d+)$">
      <action application="log" data="INFO Outbound SIP trunk placeholder for ${destination_number}"/>
      <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
    </condition>
  </extension>

  <extension name="voxagent_ai_agent">
    <condition field="destination_number" expression="^7000$">
      <action application="set" data="recording_follow_transfer=true"/>
      <action application="set" data="recording_file=/recordings/${uuid}_${caller_id_number}_to_ai_agent.wav"/>
      <action application="record_session" data="${recording_file}"/>
      <action application="set" data="STREAM_BUFFER_SIZE=100"/>
      <action application="set" data="STREAM_HEART_BEAT=15"/>
      <action application="set" data="STREAM_SUPPRESS_LOG=true"/>
      <action application="answer"/>
      <action application="sleep" data="500"/>
      <action application="eval" data="${uuid_audio_stream ${uuid} start ws://dograh:8010/freeswitch/media?call_id=${uuid}&amp;from=${caller_id_number}&amp;to=7000 mono 8k ${uuid}}"/>
      <action application="park"/>
    </condition>
  </extension>

  <extension name="voxagent_queue_placeholder">
    <condition field="destination_number" expression="^8000$">
      <action application="answer"/>
      <action application="log" data="INFO Queue placeholder reached"/>
      <action application="hangup"/>
    </condition>
  </extension>
</include>
